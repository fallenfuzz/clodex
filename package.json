{
  "name": "clodex",
  "version": "0.19.0",
  "description": "Visual multi-agent PTY manager for Claude and Codex CLIs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "postinstall": "node build/dev-rename-electron.js",
    "rebuild": "electron-rebuild",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac --arm64",
    "release": "scripts/release.sh"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.bogdan.clodex",
    "productName": "Clodex",
    "afterPack": "build/afterPack.js",
    "npmRebuild": false,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "identity": null
    },
    "files": [
      "*.js",
      "renderer/**/*",
      "build/tray-iconTemplate.png",
      "build/tray-iconTemplate@2x.png",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  }
}
